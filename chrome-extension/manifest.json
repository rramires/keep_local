{
  "manifest_version": 3,
  "name": "KeepLocal — Notas Seguras Offline",
  "version": "1.0.0",
  "description": "Notas e tarefas criptografadas localmente com AES-256-GCM. Sem servidor, sem nuvem, 100% offline.",
  "minimum_chrome_version": "120",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "KeepLocal"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "permissions": []
}
